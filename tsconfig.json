{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": ".output",
    "rootDir": "server"
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", ".output"]
}
